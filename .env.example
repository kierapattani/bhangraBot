# GroupMe Selfbot Configuration
# Copy this file to .env and fill in your values

# =====================
# GroupMe API
# =====================
# Your GroupMe Access Token
# Get it from: https://dev.groupme.com/ (click "Access Token" in top right)
ACCESS_TOKEN=your_access_token_here

# Your GroupMe Group ID
# Get it from the URL when viewing your group: web.groupme.com/groups/12345678
GROUP_ID=your_group_id_here

# =====================
# Google OAuth
# =====================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new project (or select existing)
# 2. Configure OAuth consent screen (External or Internal)
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URI: http://localhost:8000/auth/callback (dev)
#    and https://yourdomain.com/auth/callback (production)

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Redirect URI (must match what's configured in Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# =====================
# JWT Authentication
# =====================
# Generate a secure random key (min 32 characters)
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# Token expiration in hours
JWT_EXPIRATION_HOURS=24

# =====================
# Authorization
# =====================
# Comma-separated list of emails allowed to use the app
# Example: user1@gmail.com,user2@gmail.com
ALLOWED_EMAILS=your_email@gmail.com

# =====================
# App Configuration
# =====================
# Frontend URL for redirects (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Environment: development or production
# In production, cookies will require HTTPS
ENVIRONMENT=development
